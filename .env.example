# App
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/wellspring

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30

# Supabase
# Wellspring uses Supabase as hosted PostgreSQL.
# Do not use Supabase Auth or Supabase Storage for application features.
NEXT_PUBLIC_SUPABASE_URL=https://tkxrirjcdkeptkiwhhqy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-publishable-key

# AWS S3
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET=mmr-statistics-uploads-dev
S3_PRESIGNED_URL_EXPIRES_SECONDS=300
MAX_MEDIA_UPLOAD_BYTES=524288000
