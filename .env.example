# App
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# API
API_PORT=4000

# Database
DATABASE_ADMIN_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
DATABASE_URL=postgresql://wellspring_app:replace-with-runtime-role-password@db.your-project-ref.supabase.co:5432/postgres

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30

# AWS S3
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET=mmr-statistics-uploads-dev
S3_PUBLIC_BASE_URL=https://mmr-statistics-uploads-dev.s3.us-east-1.amazonaws.com
S3_PRESIGNED_URL_EXPIRES_SECONDS=300
MAX_MEDIA_UPLOAD_BYTES=524288000
